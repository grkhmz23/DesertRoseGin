# Shopify Storefront API Configuration
# Get these from your Shopify Admin > Settings > Apps and sales channels > Develop apps

# Client-side (Vite) - Public, safe to expose
VITE_SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
VITE_SHOPIFY_STOREFRONT_TOKEN=your_storefront_access_token

# Server-side (Node.js) - Private, keep secret
SHOPIFY_STORE_URL=your-store.myshopify.com
SHOPIFY_STOREFRONT_TOKEN=your_private_access_token

# Database (if using PostgreSQL)
DATABASE_URL=postgresql://user:password@host:port/database

# Analytics (optional)
VITE_CLOUDFLARE_ANALYTICS_TOKEN=your_cloudflare_token
